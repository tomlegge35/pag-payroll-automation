# =============================================================================
# PAG Payroll Automation - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git. It is already listed in .gitignore.
#
# SECURITY NOTE: SUPABASE_SERVICE_ROLE_KEY must NEVER be used in any file
# under src/app/ (frontend code). It is only permitted in:
#   - netlify/functions/
#   - src/lib/supabase/server.ts (createAdminClient only)
# =============================================================================

# --- Supabase (required) ---
# Find in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Microsoft Graph API (required for scheduled email functions) ---
# Find in: Azure Portal > App Registrations > PAG Payroll Automation > Overview/Certificates
# This app uses client_credentials (app-only) auth. No refresh token is needed.
# GRAPH_CLIENT_SECRET expires - check Azure Portal for expiry date and rotate annually.
GRAPH_TENANT_ID=your-azure-tenant-id
GRAPH_CLIENT_ID=your-azure-app-client-id
GRAPH_CLIENT_SECRET=your-azure-client-secret

# Mailbox monitored for incoming payroll emails
PAYROLL_EMAIL=payroll@premieradvisory.co.uk

# --- Application (required) ---
# Use http://localhost:3000 for local dev, https://pag-payroll.netlify.app for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
